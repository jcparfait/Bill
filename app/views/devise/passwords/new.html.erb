<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-kicker">THE BARTENDER</div>
      <h1>Mot de passe oublié</h1>
      <p>
        Ça arrive. Même aux habitués.
        Indique ton email, on t’envoie de quoi retrouver le chemin du comptoir.
      </p>
    </div>

    <%= simple_form_for(resource,
                        as: resource_name,
                        url: password_path(resource_name),
                        html: { method: :post }) do |f| %>
      <%= f.error_notification %>

      <div class="auth-form-inputs">
        <%= f.input :email,
                    label: "Email",
                    required: true,
                    autofocus: true,
                    input_html: {
                      autocomplete: "email",
                      class: "auth-input"
                    } %>
      </div>

      <div class="auth-actions">
        <%= f.button :submit,
                     "Recevoir les instructions",
                     class: "auth-submit" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
