<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-kicker">THE BARTENDER</div>
      <h1>Nouveau mot de passe</h1>
      <p>
        Choisis quelque chose de solide.
        Pas “mojito123”, même si l’ambiance s’y prête.
      </p>
    </div>

    <%= simple_form_for(resource,
                        as: resource_name,
                        url: password_path(resource_name),
                        html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <%= f.input :reset_password_token, as: :hidden %>
      <%= f.full_error :reset_password_token %>

      <div class="auth-form-inputs">
        <%= f.input :password,
                    label: "Nouveau mot de passe",
                    required: true,
                    autofocus: true,
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: {
                      autocomplete: "new-password",
                      class: "auth-input"
                    } %>

        <%= f.input :password_confirmation,
                    label: "Confirmer le nouveau mot de passe",
                    required: true,
                    input_html: {
                      autocomplete: "new-password",
                      class: "auth-input"
                    } %>
      </div>

      <div class="auth-actions">
        <%= f.button :submit,
                     "Changer mon mot de passe",
                     class: "auth-submit" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
