<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-kicker">THE BARTENDER</div>
      <h1>Se connecter</h1>
      <p>Reprenez votre place au comptoir.</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="auth-form-inputs">
        <%= f.input :email,
                    label: "Email",
                    required: false,
                    autofocus: true,
                    input_html: {
                      autocomplete: "email",
                      class: "auth-input"
                    } %>

        <%= f.input :password,
                    label: "Mot de passe",
                    required: false,
                    input_html: {
                      autocomplete: "current-password",
                      class: "auth-input"
                    } %>

        <%= f.input :remember_me,
                    as: :boolean,
                    label: "Se souvenir de moi" if devise_mapping.rememberable? %>
      </div>

      <div class="auth-actions">
        <%= f.button :submit, "Se connecter", class: "auth-submit" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
