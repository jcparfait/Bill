<%# app/views/cocktails/show.html.erb %>
<div class= cocktailcontainer>

  <div class="cocktail-show">
    <%= link_to cocktails_path, class: "cocktail-back" do %>
      <span class="back-arrow">‹</span>
    <% end %>

    <div class="cocktail-layout">
      <div class="cocktail-info">
        <div class="cocktail-header">
          <h1><%= @cocktail.name %></h1>
          <p class="cocktail-mood"><%= @cocktail.mood.capitalize %></p>
        </div>

        <div class="cocktail-details">
          <div class="cocktail-section">
            <h3>Ingrédients</h3>
            <p><%= @cocktail.ingredients %></p>
          </div>

          <div class="cocktail-section">
            <h3>Recette</h3>
            <p><%= @cocktail.recipe %></p>
          </div>
        </div>

        <div class="cocktail-actions">
          <%= link_to "Modifier", edit_cocktail_path(@cocktail), class: "btn-cocktail btn-edit" %>
          <%= link_to "Supprimer", cocktail_path(@cocktail),
              data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr ?" },
              class: "btn-cocktail btn-delete" %>
        </div>
      </div>

      <div class="cocktail-photo">
        <%= cocktail_image(@cocktail) %>
      </div>
    </div>
  </div>
</div>
