<%# app/views/cocktails/show.html.erb %>

<div class="cocktailcontainer">
  <div class="cocktail-show">
    <%= link_to cocktails_path, class: "cocktail-back" do %>
      <span class="back-arrow">‹</span>
    <% end %>

    <div class="cocktail-layout">
      <div class="cocktail-info">
        <div class="cocktail-header">
          <h1><%= @cocktail.name %></h1>

          <% if @cocktail.mood.present? %>
            <p class="cocktail-mood"><%= @cocktail.mood.capitalize %></p>
          <% end %>
        </div>

        <div class="cocktail-details">
          <div class="cocktail-section">
            <h3>Ingrédients</h3>

            <div class="cocktail-show-text">
              <%= simple_format(@cocktail.ingredients) %>
            </div>
          </div>

          <div class="cocktail-section">
            <h3>Recette</h3>

            <div class="cocktail-show-text">
              <%= simple_format(@cocktail.recipe) %>
            </div>
          </div>
        </div>

        <div class="cocktail-actions">
          <%= link_to "Modifier",
                      edit_cocktail_path(@cocktail),
                      class: "btn-cocktail btn-edit" %>

          <%= link_to "Supprimer",
                      cocktail_path(@cocktail),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "Êtes-vous sûr ?"
                      },
                      class: "btn-cocktail btn-delete" %>
        </div>
      </div>

      <div class="cocktail-photo">
        <% if @cocktail.image_url.present? %>
          <%= image_tag @cocktail.image_url,
                        alt: @cocktail.name,
                        class: "cocktail-show-image" %>
        <% else %>
          <%= cocktail_image(@cocktail) %>
        <% end %>
      </div>
    </div>
  </div>
</div>
