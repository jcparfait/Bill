<div class="cocktails-page">
  <div class="cocktails-hero">
    <div class="cocktails-hero-overlay">
      <span class="menu-subtitle">BILL</span>

      <h1>Mes cocktails</h1>

      <p>
        Les recommandations que tu as gardées. Une petite cave personnelle, mais avec moins de poussière.
      </p>
    </div>
  </div>

  <div class="cocktails-content">
    <div class="cocktails-header">
      <%= link_to "Demander une recommandation",
                  chats_path,
                  data: { turbo_method: :post },
                  class: "new-cocktail-btn" %>
    </div>

    <% if @cocktails.any? %>
      <div class="cocktails-grid">
        <% @cocktails.each do |cocktail| %>
          <%= link_to cocktail_path(cocktail), class: "cocktail-card" do %>
            <div class="cocktail-card-content compact">
              <div class="cocktail-glass">
                <% if cocktail.image_url.present? %>
                  <%= image_tag cocktail.image_url, alt: cocktail.name %>
                <% else %>
                  <%= image_tag "cocktails/#{cocktail.name.parameterize}.jpg", alt: cocktail.name %>
                <% end %>
              </div>

              <div class="cocktail-info">
                <h2><%= cocktail.name %></h2>

                <% if cocktail.mood.present? %>
                  <p class="cocktail-mood"><%= cocktail.mood %></p>
                <% end %>

                <p class="cocktail-description">
                  Recommandé par Bill, donc probablement défendable devant témoins.
                </p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-chats">
        <h2>Aucun cocktail gardé.</h2>
        <p>Commence une conversation avec Bill et ajoute une recommandation à ta collection.</p>
        <%= link_to "Parler à Bill", chats_path, data: { turbo_method: :post }, class: "new-cocktail-btn" %>
      </div>
    <% end %>
  </div>
</div>
