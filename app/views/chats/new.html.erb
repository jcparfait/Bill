<section class="chat-hero">

  <div class="hero-overlay">

    <div class="hero-content">
      <span class="hero-subtitle">
        The Bartender
      </span>

      <h1>Talk to The Bartender</h1>

      <p>
        Start a conversation with the bartender.
        Tell him your mood, your day,
        or what kind of evening you are having.
      </p>

      <%= button_to "Start a conversation",
                    chats_path,
                    method: :post,
                    class: "hero-btn" %>
    </div>

  </div>

</section>
