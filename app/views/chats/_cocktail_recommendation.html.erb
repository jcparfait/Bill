<div class="cocktail-card cocktail-card-slide-in"
     data-controller="cocktail-card"
     data-cocktail-card-chat-id-value="<%= chat.id %>">

  <button type="button"
          class="cocktail-card-collapse"
          data-action="click->cocktail-card#close">
    ›
  </button>

  <div class="cocktail-card-header">
    <span class="cocktail-card-label">Recommandation</span>
    <h2><%= cocktail.name %></h2>
    <% if cocktail.mood.present? %>
      <p class="cocktail-card-mood"><%= cocktail.mood.capitalize %></p>
    <% end %>
  </div>

  <div class="cocktail-card-scroll">
    <% if cocktail.image_url.present? %>
      <div class="cocktail-card-image">
        <%= image_tag cocktail.image_url,
                      alt: cocktail.name,
                      class: "cocktail-card-img" %>
      </div>
    <% end %>

    <div class="cocktail-card-details">
      <div class="cocktail-card-section">
        <h4>Ingrédients</h4>
        <div class="cocktail-card-text">
          <%= simple_format(cocktail.ingredients) %>
        </div>
      </div>

      <div class="cocktail-card-section">
        <h4>Recette</h4>
        <div class="cocktail-card-text">
          <%= simple_format(cocktail.recipe) %>
        </div>
      </div>
    </div>
  </div>

  <div class="cocktail-card-actions">
    <% if cocktail.saved? %>
      <button type="button"
              class="cocktail-card-accept is-saved"
              data-action="click->cocktail-card#close">
        Déjà dans mes cocktails
      </button>

      <button type="button"
              class="cocktail-card-btn-decline"
              data-action="click->cocktail-card#close">
        Non merci
      </button>
    <% else %>
      <button type="button"
              class="cocktail-card-accept"
              data-action="click->cocktail-card#accept">
        Ajouter à mes cocktails
      </button>

      <button type="button"
              class="cocktail-card-btn-decline"
              data-action="click->cocktail-card#decline">
        Non merci
      </button>
    <% end %>
  </div>
</div>
