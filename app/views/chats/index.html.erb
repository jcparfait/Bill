<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My conversations</h1>

    <%= link_to "New conversation", new_chat_path, class: "btn btn-primary" %>
  </div>

  <% if @chats.any? %>
    <% @chats.each do |chat| %>
      <div class="card mb-3">
        <div class="card-body">
          <h2><%= chat.title %></h2>

          <% if chat.cocktail.present? %>
            <p class="text-muted">
              Recommended cocktail: <%= chat.cocktail.name %>
            </p>
          <% else %>
            <p class="text-muted">
              No cocktail recommended yet.
            </p>
          <% end %>

          <%= link_to "Open conversation", chat_path(chat), class: "btn btn-primary" %>

          <%= link_to "Delete",
                      chat_path(chat),
                      data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                      class: "btn btn-outline-danger" %>
        </div>
      </div>
    <% end %>
  <% else %>
    <p>You have no conversations yet.</p>
  <% end %>
</div>
