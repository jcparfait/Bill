<div class="chats-page">

  <div class="chats-hero">

    <div class="chats-hero-overlay">

      <span class="menu-subtitle">
        THE BARTENDER
      </span>

      <h1>Conversations</h1>

      <p>
        Fragments of evenings,
        moods and quiet thoughts.
      </p>

    </div>

  </div>

  <div class="chats-content">

    <div class="chats-header">

      <%= link_to "＋ New Conversation",
      new_chat_path,
      class: "new-chat-btn" %>

    </div>

    <% if @chats.any? %>

      <div class="chats-list">

        <% @chats.each do |chat| %>

          <div class="chat-card">

            <div class="chat-card-content">

              <div class="chat-icon">
                ✦
              </div>

              <div class="chat-info">

                <h2>
                  <%= chat.title.presence || "Untitled conversation" %>
                </h2>

                <p class="chat-mood">
                  <% if chat.cocktail.present? %>


                    Recommended cocktail:
                    <%= chat.cocktail.name %>


                  <% else %>


                    No cocktail recommended yet.


                  <% end %>
                </p>

              </div>

              <div class="chat-actions">

                <%= link_to "Open",
                chat_path(chat),
                class: "chat-open-btn" %>

                <%= link_to "Delete",
                chat_path(chat),
                data: {
                  turbo_method: :delete,
                  turbo_confirm: "Delete this conversation?"
                },
                class: "chat-delete-btn" %>

              </div>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <div class="empty-chats">

        <h2>No conversations yet.</h2>

        <p>
          Start your first conversation with the bartender.
        </p>

      </div>

    <% end %>

  </div>

</div>
