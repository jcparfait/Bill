<div class="chat-page">

  <div class="chat-header">
    <%= link_to "← My conversations", chats_path, class: "back-link" %>

    <div class="chat-title-block">
      <span class="chat-subtitle">Conversation</span>
      <h1><%= @chat.title %></h1>
    </div>
  </div>

  <% if @chat.cocktail.present? %>
    <div class="cocktail-recommendation">
      <div class="cocktail-badge">
        🍸 Bartender's Choice
      </div>

      <h2><%= @chat.cocktail.name %></h2>

      <div class="cocktail-section">
        <strong>Ingredients</strong>
        <p><%= @chat.cocktail.ingredients %></p>
      </div>

      <div class="cocktail-section">
        <strong>Recipe</strong>
        <p><%= @chat.cocktail.recipe %></p>
      </div>
    </div>
  <% end %>

  <div class="messages-container">

    <% if @chat.messages.any? %>

      <% @chat.messages.each do |message| %>

        <div class="message-row <%= message.role == 'user' ? 'user-row' : 'assistant-row' %>">

          <div class="message-bubble <%= message.role == 'user' ? 'user-bubble' : 'assistant-bubble' %>">

            <div class="message-role">
              <%= message.role == "user" ? "You" : "The Bartender" %>
            </div>

            <p>
              <%= message.content %>
            </p>

          </div>

        </div>

      <% end %>

    <% else %>

      <div class="message-row assistant-row">

        <div class="message-bubble assistant-bubble">
          <div class="message-role">
            The Bartender
          </div>

          <p>
            Good evening. What brings you here tonight?
          </p>
        </div>

      </div>

    <% end %>

  </div>

  <div class="chat-input-container">

    <%= simple_form_for [@chat, @message], html: { class: "chat-form" } do |f| %>

      <%= f.input :content,
                  label: false,
                  placeholder: "Tell the bartender how your evening is going...",
                  input_html: {
                    class: "chat-input"
                  } %>

      <%= f.submit "Send",
                  class: "chat-submit-btn" %>

    <% end %>

  </div>

</div>
