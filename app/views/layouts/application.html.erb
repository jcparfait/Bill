<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Bartender" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="The Bartender">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= user_signed_in? ? 'logged-in' : 'logged-out' %>">
    <% if user_signed_in? %>
      <nav class="bartender-navbar">
        <%= link_to new_chat_path, class: "navbar-brand" do %>
          <div class="navbar-icon">♔</div>

          <div class="navbar-title">
            <span>The</span>
            <strong>Bartender</strong>
          </div>
        <% end %>

        <div class="navbar-links">
          <%= link_to "Nouveau Chat", new_chat_path, class: "navbar-link" %>
          <%= link_to "Mes Chats", chats_path, class: "navbar-link" %>
          <%= link_to "Mes Cocktails", cocktails_path, class: "navbar-link" %>
        </div>

        <div class="navbar-actions">
          <%= link_to "Se déconnecter",
                      destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: "navbar-logout" %>
        </div>
      </nav>

      <div class="app-layout">
        <main id="main-content" class="app-content">
          <%= render "shared/flashes" %>
          <%= yield %>
        </main>
      </div>

      <nav class="mobile-bottom-nav">
        <%= link_to new_chat_path,
                    class: "mobile-nav-link #{'active' if controller_name == 'chats' && ['new', 'show'].include?(action_name)}" do %>
          <i class="fa-solid fa-martini-glass mobile-nav-icon"></i>
          <span class="mobile-nav-label">Bar</span>
        <% end %>

        <details class="mobile-nav-menu">
          <summary class="mobile-nav-link mobile-nav-menu-button">
            <i class="fa-solid fa-bars mobile-nav-icon"></i>
            <span class="mobile-nav-label">Menu</span>
          </summary>

          <div class="mobile-nav-panel">
            <%= link_to chats_path, class: "mobile-nav-panel-link" do %>
              <i class="fa-regular fa-clock"></i>
              <span>Mes Conversations</span>
            <% end %>

            <button type="button" class="mobile-nav-panel-link mobile-sound-toggle">
              <i class="fa-solid fa-volume-high"></i>
              <span>Son</span>
            </button>

            <%= link_to destroy_user_session_path,
                        data: { turbo_method: :delete },
                        class: "mobile-nav-panel-link mobile-nav-danger" do %>
              <i class="fa-solid fa-arrow-right-from-bracket"></i>
              <span>Déconnexion</span>
            <% end %>
          </div>
        </details>

        <%= link_to cocktails_path,
                    class: "mobile-nav-link #{'active' if controller_name == 'cocktails'}" do %>
          <i class="fa-solid fa-book-open mobile-nav-icon"></i>
          <span class="mobile-nav-label">Cocktails</span>
        <% end %>
      </nav>

      <audio id="bg-music" loop autoplay>
        <source src="<%= asset_path('music.wav') %>" type="audio/wav">
      </audio>

      <button id="music-toggle" class="music-btn">
        ♫
      </button>

        const syncMusicState = () => {
          if (!audio || !button) return

          const isMuted = localStorage.getItem("music-muted") === "true"

          audio.volume = 0.25
          audio.muted = isMuted
          button.classList.toggle("muted", isMuted)
          button.innerText = isMuted ? "♫̸" : "♫"
        }

        if (audio && button) {
          syncMusicState()

          audio.addEventListener("play", syncMusicState)

          audio.play().catch(() => {})

          button.onclick = () => {
            const newMutedState = !audio.muted

            localStorage.setItem(
              "music-muted",
              newMutedState ? "true" : "false"
            )

            audio.muted = newMutedState
            syncMusicState()

            audio.play().catch(() => {})
          }
        }

        const forceScrollMessagesToBottom = () => {
          setTimeout(() => {
            const bottom = document.getElementById("messages-bottom")
            const messages = document.getElementById("messages")
            const main = document.getElementById("main-content")

            if (bottom) {
              bottom.scrollIntoView({ behavior: "auto", block: "end" })
            }

            if (messages) {
              messages.scrollTop = messages.scrollHeight
            }

            if (main) {
              main.scrollTop = main.scrollHeight
            }

            window.scrollTo({
              top: document.documentElement.scrollHeight,
              behavior: "auto"
            })
          }, 0)
        }

        forceScrollMessagesToBottom()

        document.addEventListener("turbo:stream-render", () => {
          forceScrollMessagesToBottom()
        })

        document.addEventListener("turbo:render", () => {
          forceScrollMessagesToBottom()
        })

        const messagesContainer = document.getElementById("messages")

        if (messagesContainer) {
          const observer = new MutationObserver(() => {
            forceScrollMessagesToBottom()
          })

          observer.observe(messagesContainer, {
            childList: true,
            subtree: true,
            characterData: true
          })
        }
      })
    </script>
  </body>
</html>
