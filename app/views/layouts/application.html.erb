<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bill" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bill">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= user_signed_in? ? 'logged-in' : 'logged-out' %>">
    <% if user_signed_in? %>
      <nav class="app-quick-actions" aria-label="Navigation principale">
        <%= link_to cocktails_path, class: "quick-action-link", title: "Mes cocktails", aria: { label: "Mes cocktails" } do %>
          <i class="fa-solid fa-martini-glass-citrus"></i>
        <% end %>

        <%= link_to profile_path, class: "quick-action-link", title: "Profil", aria: { label: "Profil" } do %>
          <i class="fa-regular fa-user"></i>
        <% end %>
      </nav>

      <div class="app-layout">
        <main id="main-content" class="app-content">
          <%= render "shared/flashes" %>
          <%= yield %>
        </main>
      </div>

      <audio id="bg-music" loop preload="metadata" data-turbo-permanent>
        <source src="<%= asset_path('music.mp3') %>" type="audio/wav">
      </audio>

      <button id="music-toggle" class="music-btn" data-turbo-permanent>
        ♫
      </button>
    <% else %>
      <main id="main-content" class="app-content">
        <%= render "shared/flashes" %>
        <%= yield %>
      </main>
    <% end %>

    <script>
      document.addEventListener("turbo:load", () => {
        const audio = document.getElementById("bg-music")
        const button = document.getElementById("music-toggle")

        const syncMusicState = () => {
          if (!audio || !button) return

          const isMuted = localStorage.getItem("music-muted") === "true"

          audio.volume = 0.25
          audio.muted = isMuted
          button.classList.toggle("muted", isMuted)
          button.innerText = isMuted ? "♫̸" : "♫"
        }

        if (audio && button) {
          syncMusicState()

          audio.addEventListener("play", syncMusicState)

          audio.play().catch(() => {})

          button.onclick = () => {
            const newMutedState = !audio.muted

            localStorage.setItem(
              "music-muted",
              newMutedState ? "true" : "false"
            )

            audio.muted = newMutedState
            syncMusicState()

            audio.play().catch(() => {})
          }
        }

        const forceScrollMessagesToBottom = () => {
          const messages = document.getElementById("messages")
          const bottom = document.getElementById("messages-bottom")

          // PAS une page de chat → on ne fait rien
          if (!messages || !bottom) return

          setTimeout(() => {
            bottom.scrollIntoView({
              behavior: "auto",
              block: "end"
            })

            messages.scrollTop = messages.scrollHeight
          }, 0)
        }

        forceScrollMessagesToBottom()

        document.addEventListener("turbo:stream-render", () => {
          forceScrollMessagesToBottom()
        })

        document.addEventListener("turbo:render", () => {
          forceScrollMessagesToBottom()
        })

        const messagesContainer = document.getElementById("messages")

        if (messagesContainer) {
          const observer = new MutationObserver(() => {
            forceScrollMessagesToBottom()
          })

          observer.observe(messagesContainer, {
            childList: true,
            subtree: true,
            characterData: true
          })
        }
      })
    </script>
  </body>
</html>
