<!DOCTYPE html>
<html lang="fr">
  <head>
    <% app_description = "Bill est un bar conversationnel: discute avec un barman ironique, décris ton humeur, et reçois un cocktail adapté avec recette et ingrédients." %>
    <title><%= content_for(:title) || "Bill - Bar conversationnel" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="<%= app_description %>">
    <meta name="theme-color" content="#0b0b0a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bill">
    <meta name="mobile-web-app-capable" content="yes">

    <meta property="og:site_name" content="Bill">
    <meta property="og:title" content="Bill - Bar conversationnel">
    <meta property="og:description" content="<%= app_description %>">
    <meta property="og:type" content="website">
    <meta property="og:image" content="<%= image_url('logo/logo.png') %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Bill - Bar conversationnel">
    <meta name="twitter:description" content="<%= app_description %>">
    <meta name="twitter:image" content="<%= image_url('logo/logo.png') %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= user_signed_in? ? 'logged-in' : 'logged-out' %>">
    <% if user_signed_in? %>
      <% unless current_page?(root_path) %>
        <nav class="app-home-action" aria-label="Retour accueil">
          <%= link_to root_path, class: "quick-action-link home-logo-link", title: "Accueil", aria: { label: "Accueil" } do %>
            <%= image_tag "logo/logo.png", alt: "Accueil", class: "home-logo-icon" %>
          <% end %>
        </nav>
      <% end %>

      <nav class="app-quick-actions" aria-label="Navigation principale">
        <%= link_to cocktails_path, class: "quick-action-link", title: "Mes cocktails", aria: { label: "Mes cocktails" } do %>
          <i class="fa-solid fa-martini-glass-citrus"></i>
        <% end %>

        <%= link_to profile_path, class: "quick-action-link", title: "Profil", aria: { label: "Profil" } do %>
          <i class="fa-regular fa-user"></i>
        <% end %>
      </nav>

      <div class="app-layout">
        <main id="main-content" class="app-content">
          <%= render "shared/flashes" %>
          <%= yield %>
        </main>
      </div>

      <audio id="bg-music" loop preload="metadata" data-turbo-permanent>
        <source src="<%= asset_path('music.mp3') %>" type="audio/wav">
      </audio>

      <button class="music-btn desktop-music-btn" data-music-toggle data-turbo-permanent aria-label="Activer ou couper la musique">
        <i class="fa-solid fa-volume-high"></i>
      </button>

      <nav class="mobile-bottom-nav" aria-label="Navigation mobile">
        <%= link_to cocktails_path, class: "mobile-nav-action", title: "Mes cocktails", aria: { label: "Mes cocktails" } do %>
          <i class="fa-solid fa-martini-glass-citrus"></i>
        <% end %>

        <%= link_to profile_path, class: "mobile-nav-action", title: "Profil", aria: { label: "Profil" } do %>
          <i class="fa-regular fa-user"></i>
        <% end %>

        <button class="mobile-nav-action mobile-sound-action" data-music-toggle data-turbo-permanent aria-label="Activer ou couper la musique">
          <i class="fa-solid fa-volume-high"></i>
        </button>
      </nav>
    <% else %>
      <main id="main-content" class="app-content">
        <%= render "shared/flashes" %>
        <%= yield %>
      </main>
    <% end %>

    <script>
      document.addEventListener("turbo:load", () => {
        const audio = document.getElementById("bg-music")
        const buttons = document.querySelectorAll("[data-music-toggle]")

        const syncMusicState = () => {
          if (!audio || buttons.length === 0) return

          const isMuted = localStorage.getItem("music-muted") === "true"

          audio.volume = 0.25
          audio.muted = isMuted

          buttons.forEach((button) => {
            button.classList.toggle("muted", isMuted)
            button.innerHTML = isMuted
              ? '<i class="fa-solid fa-volume-xmark"></i>'
              : '<i class="fa-solid fa-volume-high"></i>'
          })
        }

        if (audio && buttons.length > 0) {
          syncMusicState()

          audio.addEventListener("play", syncMusicState)

          audio.play().catch(() => {})

          buttons.forEach((button) => {
            button.onclick = () => {
              const newMutedState = !audio.muted

              localStorage.setItem(
                "music-muted",
                newMutedState ? "true" : "false"
              )

              audio.muted = newMutedState
              syncMusicState()

              audio.play().catch(() => {})
            }
          })
        }

        const forceScrollMessagesToBottom = () => {
          const messages = document.getElementById("messages")
          const bottom = document.getElementById("messages-bottom")

          if (!messages || !bottom) return

          setTimeout(() => {
            bottom.scrollIntoView({
              behavior: "auto",
              block: "end"
            })

            messages.scrollTop = messages.scrollHeight
          }, 0)
        }

        forceScrollMessagesToBottom()

        document.addEventListener("turbo:stream-render", () => {
          forceScrollMessagesToBottom()
        })

        document.addEventListener("turbo:render", () => {
          forceScrollMessagesToBottom()
        })

        const messagesContainer = document.getElementById("messages")

        if (messagesContainer) {
          const observer = new MutationObserver(() => {
            forceScrollMessagesToBottom()
          })

          observer.observe(messagesContainer, {
            childList: true,
            subtree: true,
            characterData: true
          })
        }
      })
    </script>
  </body>
</html>
