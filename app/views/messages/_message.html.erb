<div id="<%= dom_id(message) %>" class="message-row <%= message.role == "user" ? "user-row" : "assistant-row" %>">
  <div class="message-bubble <%= message.role == "user" ? "user-bubble" : "assistant-bubble" %>">
    <div class="message-role">
      <%= message.role == "user" ? "Vous" : "The Bartender" %>
    </div>
    <% if message.content.present? %>
      <p><%= message.content %></p>
    <% end %>
  </div>
</div>
