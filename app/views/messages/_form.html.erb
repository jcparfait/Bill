<div id="new_message_container">
  <%= simple_form_for [chat, message],
                      html: {
                        class: "chat-form",
                        onsubmit: "setTimeout(() => this.reset(), 0)",
                        data: { controller: "submit-on-enter" }
                      } do |f| %>
    <%= f.input :content,
                label: false,
                placeholder: "Ex : fatigué, envie de réconfort, sans gin ni menthe...",
                input_html: {
                  class: "chat-input",
                  rows: 2,
                  data: { action: "keydown->submit-on-enter#submit" }
                } %>

    <%= f.submit "Parler à Bill", class: "chat-submit-btn" %>
  <% end %>
</div>
