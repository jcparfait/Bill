<%= turbo_stream.replace "new_message_container" do %>
  <%= render "messages/form", chat: @chat, message: Message.new %>
<% end %>

<%= turbo_stream.replace dom_id(@chat, :title) do %>
  <h1 id="<%= dom_id(@chat, :title) %>"><%= @chat.display_title %></h1>
<% end %>

<% if @cocktail_was_recommended %>
  <%= turbo_stream.update "glass-animation-container" do %>
    <div class="sliding-glass"></div>
  <% end %>
<% end %>
