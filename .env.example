# Required for GitHub Models / RubyLLM integration
# Create a GitHub token with models:read access.
GITHUB_TOKEN=your_github_token_here

# Optional: override GitHub Models defaults
GITHUB_MODELS_API_BASE=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4o

# Optional fallback if you prefer OpenAI directly instead of GitHub Models
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Optional local Rails settings
# RAILS_ENV=development
# RAILS_LOG_LEVEL=debug
