# Required for GitHub Models / RubyLLM integration
# Create a fine-grained GitHub token with Account permissions > Models > Read-only.
GITHUB_TOKEN=your_github_token_here

# Optional: override GitHub Models defaults used by Le Wagon / Azure OpenAI Playground
GITHUB_MODELS_API_BASE=https://models.inference.ai.azure.com
GITHUB_MODELS_MODEL=gpt-4o

# Optional fallback if you prefer OpenAI directly instead of GitHub Models
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Optional local Rails settings
# RAILS_ENV=development
# RAILS_LOG_LEVEL=debug
